# Study Session Monitoring and Testing Configuration

# Grok AI API Key (xAI) for Question Generation, Assessment, and RAG Chat
XAI_API_KEY=your_grok_api_key_here

# ML Model Path (relative to adaptive_learning app)
ML_MODEL_PATH=adaptive_learning/ml_models/random_forest_classifier_model.joblib

# Email Delivery — Gmail SMTP (recommended, free, no limits)
# Steps: Go to Google Account → Security → 2-Step Verification → App Passwords → Generate
GMAIL_EMAIL=your.email@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password
FROM_NAME=Velocity Learning

# Or use Resend (free 3,000 emails/month): https://resend.com
# RESEND_API_KEY=re_xxxxxxxxxxxx
# FROM_EMAIL=onboarding@resend.dev
